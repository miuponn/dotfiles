layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
    }

    tab name="edit" focus=true {
        pane command="nvim"
    }

    tab name="claude" {
        pane command="claude"
    }

    tab name="shell" {
        pane
    }
}
