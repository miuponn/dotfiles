layout {
    tab name="code" focus=true {
        pane split_direction="horizontal" {
            pane size="75%" name="editor" split_direction="vertical" {
                pane size="80%" name="nvim" close_on_exit=true {
                    command "zsh"
                    args "-i" "-c" "nvim; exec zsh -i"
                }
                pane size="20%" name="shell"
            }
            pane size="25%" name="claude" close_on_exit=true {
                command "zsh"
                args "-i" "-c" "claude; exec zsh -i"
            }
        }
    }
    tab name="git" {
        pane split_direction="vertical" {
            pane size="70%" name="lazygit"
            pane size="30%" split_direction="horizontal" {
                pane size="50%" name="claude" {
                    command "claude"
                }
                pane size="50%" name="shell"
            }
        }
    }
}
