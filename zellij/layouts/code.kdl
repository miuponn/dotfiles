layout {
    tab name="code" focus=true {
        pane split_direction="vertical" {
            pane size="55%" name="claude" {
                command "claude"
            }
            pane size="45%" split_direction="horizontal" {
                pane size="70%" name="editor" {
                    command "nvim"
                }
                pane size="30%" split_direction="vertical" {
                    pane size="60%" name="shell"
                    pane size="40%" name="files" {
                        command "yazi"
                    }
                }
            }
        }
    }
}
