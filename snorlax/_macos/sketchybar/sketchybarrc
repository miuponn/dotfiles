#!/bin/bash

CONFIG_DIR="$HOME/.config/sketchybar"
export CONFIG_DIR
PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/helpers/glyphs.sh"

sketchybar --bar \
  position=top \
  height=48 \
  margin=10 \
  y_offset=8 \
  corner_radius=20 \
  blur_radius=15 \
  border_width=0 \
  padding_left=14 \
  padding_right=14 \
  color=$BAR_BG \
  shadow.drawing=on \
  shadow.color=0x40000000 \
  shadow.distance=3 \
  shadow.angle=90 \
  sticky=on

sketchybar --default \
  icon.font="$FONT_ICON" \
  icon.color=$GROVE_FG \
  icon.padding_left=6 \
  icon.padding_right=6 \
  label.font="$FONT_LABEL" \
  label.color=$GROVE_FG \
  label.padding_left=6 \
  label.padding_right=6 \
  background.color=$ITEM_BG \
  background.corner_radius=12 \
  background.height=30 \
  background.padding_left=2 \
  background.padding_right=2 \
  scroll_texts=on

sketchybar --add event aerospace_workspace_change
sketchybar --add event window_detected
sketchybar --add event media_change "com.apple.MediaRemote.nowPlayingInfoDidChange"

source "$ITEM_DIR/apple.sh"
source "$ITEM_DIR/spaces.sh"
source "$ITEM_DIR/front_app.sh"
source "$ITEM_DIR/media.sh"
source "$ITEM_DIR/wifi.sh"
source "$ITEM_DIR/bluetooth.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/clock.sh"

sketchybar --update
